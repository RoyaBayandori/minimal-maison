# =============================================================================
# Minimal Maison — production environment (template)
# Copy to .env.production (gitignored) — never commit real values.
#
# Deploy:
#   docker compose --env-file .env.production \
#     -f docker-compose.yml -f docker-compose.prod.yml up -d
# =============================================================================

COMPOSE_PROJECT_NAME=minimal-maison
WP_ENVIRONMENT_TYPE=production

WP_DEBUG=false
WP_DEBUG_LOG=false
WP_DEBUG_DISPLAY=false

WORDPRESS_LOCALE=fa_IR
WORDPRESS_TABLE_PREFIX=wp_

WP_MEMORY_LIMIT=256M
WP_MAX_MEMORY_LIMIT=512M

DISALLOW_FILE_EDIT=true
FORCE_SSL_ADMIN=true
WP_CACHE_KEY_SALT=replace-with-long-random-string

# Public site URL (HTTPS)
WP_HOME=https://minimal.example
WP_SITEURL=https://minimal.example

NGINX_HTTP_PORT=80
# Use nginx/conf.d/production/ for 443 + certificates (see docs/PRODUCTION.md)

MYSQL_ROOT_PASSWORD=replace_me
MYSQL_DATABASE=minimal_maison
MYSQL_USER=minimal_maison
MYSQL_PASSWORD=replace_me

# Do not expose phpMyAdmin in production (profile disabled in compose override)
PHPMYADMIN_PORT=8081

# Maison contact channels (footer, concierge WhatsApp)
MM_INSTAGRAM_URL=https://www.instagram.com/minimal.maison/
MM_WHATSAPP_PHONE=
MM_WHATSAPP_URL=
MM_CONTACT_EMAIL=hello@minimal.maison
MM_CONTACT_PHONE=
