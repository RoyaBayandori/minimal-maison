# =============================================================================
# Minimal Maison — WordPress + WooCommerce + custom theme (Docker)
# Tracked on purpose: themes/, plugins/, mu-plugins/
# =============================================================================

# --- Secrets & local env (Docker reads .env from disk; never commit) ---
.env
.env.production
.env.local
.env.*.local
!.env.example
!.env.production.example

# --- OS & editor junk ---
.DS_Store
**/.DS_Store
Thumbs.db
Desktop.ini
._*

.idea/
.vscode/
*.swp
*.swo
*~

# --- Node / Vite / npm (theme frontend — add package.json in theme next) ---
node_modules/
.npm/
.pnpm-store/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/install-state.gz
.pnp.*

# Vite build output & dev cache (do not commit compiled assets yet)
dist/
.vite/

# Env files sometimes used by Vite
.env.development.local
.env.test.local

# --- Docker (local tooling only; compose files stay tracked) ---
.docker/

# --- Application logs (bind-mounted from containers) ---
logs/*
!logs/**/.gitkeep

# --- Database & project backups (generated by backup scripts / plugins) ---
backups/*
!backups/**/.gitkeep
backups/**/*.sql
backups/**/*.sql.gz
backups/**/*.tar
backups/**/*.tar.gz
backups/**/*.zip
backups/**/*.bak

# --- WordPress runtime (NOT themes / plugins / mu-plugins) ---
wordpress/wp-content/uploads/
wordpress/wp-content/cache/
wordpress/wp-content/upgrade/
wordpress/wp-content/wc-logs/
wordpress/wp-content/backups/
wordpress/wp-content/updraft/
wordpress/wp-content/ai1wm-backups/

# Drop-in caches & logs (regenerated by plugins / Redis Object Cache later)
wordpress/wp-content/debug.log
wordpress/wp-content/advanced-cache.php
wordpress/wp-content/object-cache.php
wordpress/wp-content/db.php

# Optional: language packs installed via WP-CLI (reinstall with make install-lang)
# wordpress/wp-content/languages/
