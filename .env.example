# =============================================================================
# Minimal Maison — Docker environment variables
# Copy to .env and adjust values: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=minimal-maison
WP_ENVIRONMENT_TYPE=local

# WordPress debug (only enable locally; never in production)
WP_DEBUG=false
WP_DEBUG_LOG=false
WP_DEBUG_DISPLAY=false

# Persian (RTL) locale — install language pack after first boot
WORDPRESS_LOCALE=fa_IR

# Table prefix (change before first install if desired)
WORDPRESS_TABLE_PREFIX=wp_

# Memory limits (WooCommerce-friendly)
WP_MEMORY_LIMIT=256M
WP_MAX_MEMORY_LIMIT=512M

# Security
DISALLOW_FILE_EDIT=true
FORCE_SSL_ADMIN=false
WP_CACHE_KEY_SALT=minimal-maison:change-me-in-production

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=8080

# -----------------------------------------------------------------------------
# MySQL 8 (internal Docker network only — no host port published)
# Access via: phpMyAdmin, wp-cli, or docker compose exec mysql mysql ...
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=minimal_maison
MYSQL_USER=minimal_maison
MYSQL_PASSWORD=change_me_db_password

# -----------------------------------------------------------------------------
# Redis (object cache)
# Dev: leave empty. Production: set password + enable requirepass (see docker-compose.yml TODO)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# phpMyAdmin
# -----------------------------------------------------------------------------
PHPMYADMIN_PORT=8081

# -----------------------------------------------------------------------------
# MailHog (local email capture)
# -----------------------------------------------------------------------------
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
MM_SMTP_HOST=mailhog
MM_SMTP_PORT=1025

# -----------------------------------------------------------------------------
# WordPress URLs (used after install; match NGINX_HTTP_PORT)
# -----------------------------------------------------------------------------
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080
